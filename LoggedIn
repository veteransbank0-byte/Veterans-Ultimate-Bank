<!-- ⭐ LOGOUT SCRIPT -->
<script>
    const logout = document.getElementById("logoutBtn");
    if (logout) {
        logout.onclick = function () {
            localStorage.removeItem("loggedIn");
            window.location.href = "index.html";
        };
    }
</script>

